{
  "description": "session/metaChanged replaces _meta entirely",
  "reducer": "session",
  "initial": {
    "summary": {
      "resource": "copilot:/test-session",
      "provider": "copilot",
      "title": "Test Session",
      "status": 1,
      "createdAt": 1000,
      "modifiedAt": 1000
    },
    "lifecycle": "ready",
    "turns": [],
    "_meta": {
      "git": {
        "branch": "main"
      }
    }
  },
  "actions": [
    {
      "type": "session/metaChanged",
      "_meta": {
        "git": {
          "branch": "feature"
        },
        "vscode.foo": 42
      }
    }
  ],
  "expected": {
    "summary": {
      "resource": "copilot:/test-session",
      "provider": "copilot",
      "title": "Test Session",
      "status": 1,
      "createdAt": 1000,
      "modifiedAt": 1000
    },
    "lifecycle": "ready",
    "turns": [],
    "_meta": {
      "git": {
        "branch": "feature"
      },
      "vscode.foo": 42
    }
  }
}
