{
  "description": "session/configChanged merges new values into config.values",
  "reducer": "session",
  "initial": {
    "summary": {
      "resource": "copilot:/test",
      "provider": "copilot",
      "title": "Test",
      "status": 1,
      "createdAt": 1000,
      "modifiedAt": 2000
    },
    "config": {
      "schema": {
        "type": "object",
        "properties": {
          "target": {
            "type": "string",
            "title": "Target",
            "enum": [
              "workspace",
              "worktree"
            ]
          },
          "baseBranch": {
            "type": "string",
            "title": "Base Branch",
            "enum": [
              "main",
              "develop"
            ]
          }
        }
      },
      "values": {
        "target": "worktree",
        "baseBranch": "main"
      }
    },
    "lifecycle": "ready",
    "turns": []
  },
  "actions": [
    {
      "type": "session/configChanged",
      "config": {
        "baseBranch": "develop"
      }
    }
  ],
  "expected": {
    "summary": {
      "resource": "copilot:/test",
      "provider": "copilot",
      "title": "Test",
      "status": 1,
      "createdAt": 1000,
      "modifiedAt": 9999
    },
    "config": {
      "schema": {
        "type": "object",
        "properties": {
          "target": {
            "type": "string",
            "title": "Target",
            "enum": [
              "workspace",
              "worktree"
            ]
          },
          "baseBranch": {
            "type": "string",
            "title": "Base Branch",
            "enum": [
              "main",
              "develop"
            ]
          }
        }
      },
      "values": {
        "target": "worktree",
        "baseBranch": "develop"
      }
    },
    "lifecycle": "ready",
    "turns": []
  }
}
