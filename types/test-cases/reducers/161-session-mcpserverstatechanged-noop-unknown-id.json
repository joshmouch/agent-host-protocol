      "status": 1,
      "createdAt": 1000,
      "modifiedAt": 1000
    },
    "lifecycle": "ready",
    "turns": [],
    "customizations": [
      {
        "type": "mcpServer",
        "id": "mcp-1",
        "uri": "file:///workspace/.mcp/servers.json",
        "name": "Filesystem",
        "enabled": true,
        "state": { "kind": "ready" },
        "channel": "mcp://filesystem"
      }
    ]
  }
}
