      "provider": "copilot",
      "title": "Test Session",
      "status": 1,
      "createdAt": 1000,
      "modifiedAt": 1000
    },
    "lifecycle": "ready",
    "turns": [],
    "customizations": [
      {
        "type": "mcpServer",
