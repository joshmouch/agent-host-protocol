  "initial": {
    "threads": [
      {
        "id": "t-1",
        "turnId": "turn-1",
        "resource": "file:///src/a.ts",
        "range": {
          "start": { "line": 0, "character": 0 },
          "end": { "line": 0, "character": 5 }
        },
        "comments": [
          { "id": "c-1", "text": "keep" }
        ]
      },
      {
        "id": "t-2",
        "turnId": "turn-1",
        "resource": "file:///src/b.ts",
        "range": {
          "start": { "line": 2, "character": 0 },
          "end": { "line": 2, "character": 4 }
        },
        "comments": [
          { "id": "c-2", "text": "drop me" }
