{
  "description": "toolCallContentChanged sets content on a running tool call",
  "reducer": "session",
  "initial": {
    "summary": {
      "resource": "copilot:/test-session",
      "provider": "copilot",
      "title": "Test Session",
      "status": 8,
      "createdAt": 1000,
      "modifiedAt": 2000
    },
    "lifecycle": "ready",
    "turns": [],
    "activeTurn": {
      "id": "turn-1",
      "userMessage": { "text": "Hello" },
      "responseParts": [
        {
          "kind": "toolCall",
          "toolCall": {
            "status": "running",
            "toolCallId": "tc-1",
            "toolName": "bash",
            "displayName": "Run Command",
            "invocationMessage": "Running command",
            "toolInput": "ls -la",
            "confirmed": "user-action"
          }
        }
      ],
      "usage": null
    }
  },
  "actions": [
    {
      "type": "session/toolCallContentChanged",
      "session": "copilot:/test-session",
      "turnId": "turn-1",
      "toolCallId": "tc-1",
      "content": [
        { "type": "terminal", "resource": "agenthost:/terminal/1", "title": "bash" }
      ]
    }
  ],
  "expected": {
    "summary": {
      "resource": "copilot:/test-session",
      "provider": "copilot",
      "title": "Test Session",
      "status": 8,
      "createdAt": 1000,
      "modifiedAt": 2000
    },
    "lifecycle": "ready",
    "turns": [],
    "activeTurn": {
      "id": "turn-1",
      "userMessage": { "text": "Hello" },
      "responseParts": [
        {
          "kind": "toolCall",
          "toolCall": {
            "status": "running",
            "toolCallId": "tc-1",
            "toolName": "bash",
            "displayName": "Run Command",
            "invocationMessage": "Running command",
            "toolInput": "ls -la",
            "confirmed": "user-action",
            "content": [
              { "type": "terminal", "resource": "agenthost:/terminal/1", "title": "bash" }
            ]
          }
        }
      ],
      "usage": null
    }
  }
}
